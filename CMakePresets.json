{
	"version": 3,
	"configurePresets": [
		{
			"name": "base",
			"hidden": true,
			"binaryDir": "${sourceDir}/build",
			"cacheVariables": {
				"WLCLIENT_ASSERT_ENABLED": "ON",
				"WLCLIENT_BUILD_TESTS": "ON",
				"WLCLIENT_BUILD_SANDBOX": "ON",
				"WLCLIENT_BACKEND": "EGL"
			}
		},
		{
			"name": "debug-base",
			"hidden": true,
			"inherits": "base",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Debug",
				"WLCLIENT_LIBRARY_SHARED": "ON",
				"WLCLIENT_USE_LOGGING": "ON"
			}
		},
		{
			"name": "release-base",
			"hidden": true,
			"inherits": "base",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Release",
				"WLCLIENT_LIBRARY_SHARED": "OFF",
				"WLCLIENT_USE_LOGGING": "OFF"
			}
		},

		{
			"name": "debug",
			"displayName": "Debug configuration (Clang configuration alias).",
			"description": "Alias to clang-debug.",
			"inherits": "clang-debug"
		},
		{
			"name": "release",
			"displayName": "Release configuration (Clang configuration alias).",
			"description": "Alias to clang-release.",
			"inherits": "clang-release"
		},

		{
			"name": "clang-debug",
			"displayName": "Clang debug configuration.",
			"description": "Debug build configured with the native Clang toolchain.",
			"inherits": "debug-base",
			"toolchainFile": "${sourceDir}/cmake/toolchains/clang-native.cmake"
		},
		{
			"name": "clang-release",
			"displayName": "Clang release configuration.",
			"description": "Release build configured with the native Clang toolchain.",
			"inherits": "release-base",
			"toolchainFile": "${sourceDir}/cmake/toolchains/clang-native.cmake"
		},
		{
			"name": "gcc-debug",
			"displayName": "Gcc debug configuration.",
			"description": "Debug build configured with the native gcc toolchain.",
			"inherits": "debug-base",
			"toolchainFile": "${sourceDir}/cmake/toolchains/gcc-native.cmake"
		},
		{
			"name": "gcc-release",
			"displayName": "Gcc release configuration.",
			"description": "Release build configured with the native gcc toolchain.",
			"inherits": "release-base",
			"toolchainFile": "${sourceDir}/cmake/toolchains/gcc-native.cmake"
		}
	]
}
